           -0.1957 ,0.4437 ,0.2188 ,0.2272 ,-0.1971], # GP340
    'x8': [0.24863, 0.13134, 0.18506, 0.04595, 0.2476, 0.13058, 0.18086, 0.04631,
           0.24795, 0.12782, 0.17826, 0.04875, 0.24672, 0.12456, 0.17929, 0.05065,
           0.24821, 0.11971, 0.17179, 0.05177, 0.25326, 0.11858, 0.17014, 0.05236,
           0.25578, 0.14428, 0.19764, 0.0583, 0.26067, 0.14868, 0.20167, 0.06495,
