    'x3': [5]*36 + [10]*4 + [15]*4 + [20]*4,  # Conc
    'x4': [1, 5, 4, 10 ] *12,  # DOPC
    'x5': [2, 3, 2, 0 ] *12,  # Chol
    'x6': [7, 2, 4, 0 ] *12,  # ESM
    'x7': [0.4255 ,0.1994 ,0.2144 ,-0.1645 ,0.4240 ,0.1912 ,0.1815 ,-0.2160,
           0.4114 ,0.1779 ,0.1666 ,-0.2285 ,0.4079 ,0.1710 ,0.1445 ,-0.2332,
           0.4141 ,0.1682 ,0.1317 ,-0.2390 ,0.4042 ,0.1578 ,0.1199 ,-0.2343,
